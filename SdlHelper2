#pragma once

#include <QObject>
#include <QTimer>
#include <SDL2/SDL.h>

class SdlHelper : public QObject {
    Q_OBJECT

public:
    explicit SdlHelper(QObject *parent = nullptr)
        : QObject(parent)
        , controller(nullptr)
        , pollTimer(new QTimer(this))
    {
        // Init SDL here, in the same thread that will poll events
        if (SDL_Init(SDL_INIT_GAMECONTROLLER) != 0) {
            lastError = QString::fromUtf8(SDL_GetError());
            return;
        }

        if (SDL_NumJoysticks() < 1) {
            lastError = QStringLiteral("No joysticks found");
            return;
        }

        controller = SDL_GameControllerOpen(0);
        if (!controller) {
            lastError = QString::fromUtf8(SDL_GetError());
            return;
        }

        SDL_GameControllerEventState(SDL_ENABLE);
        SDL_JoystickEventState(SDL_ENABLE);

        // Init button state
        for (int i = 0; i < SDL_CONTROLLER_BUTTON_MAX; ++i) {
            lastState[i] = false;
        }

        connect(pollTimer, &QTimer::timeout,
                this, &SdlHelper::pollEvents);
        pollTimer->start(10); // 10 ms polling
    }

    ~SdlHelper() override {
        if (pollTimer) {
            pollTimer->stop();
        }

        if (controller) {
            SDL_GameControllerClose(controller);
            controller = nullptr;
        }

        SDL_QuitSubSystem(SDL_INIT_GAMECONTROLLER);
        SDL_Quit();
    }

    Q_INVOKABLE bool initGamepad() {
        // Kept for API compatibility; real init is in ctor.
        // Return true only if controller is valid.
        return controller != nullptr;
    }

    Q_INVOKABLE QString getError() const {
        return lastError;
    }

signals:
    void buttonReleased(int button);
    void buttonPressed(int button);
    void axisMoved(int axis, int value);

private:
    SDL_GameController *controller;
    QTimer *pollTimer;
    bool lastState[SDL_CONTROLLER_BUTTON_MAX];
    QString lastError;

    void pollEvents() {
        if (!controller) {
            return;
        }

        SDL_Event e;
        SDL_PumpEvents();

        while (SDL_PollEvent(&e)) {
            switch (e.type) {
            case SDL_CONTROLLERAXISMOTION:
                emit axisMoved(e.caxis.axis, e.caxis.value);
                break;
            default:
                break;
            }
        }

        // Button state tracking
        for (int b = 0; b < SDL_CONTROLLER_BUTTON_MAX; ++b) {
            bool current = SDL_GameControllerGetButton(
                controller,
                static_cast<SDL_GameControllerButton>(b)
                );

            if (current && !lastState[b]) {
                emit buttonPressed(b);
            } else if (!current && lastState[b]) {
                emit buttonReleased(b);
            }

            lastState[b] = current;
        }
    }
};
