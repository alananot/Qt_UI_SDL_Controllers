from picamera2 import Picamera2
import cv2
import numpy as np
import threading
import time
from flask import Flask, Response, jsonify
import serial

app = Flask(__name__)

picam2 = Picamera2()
config = picam2.create_video_configuration(
    main={"size": (640, 480)},
    controls={"FrameRate": 60}
)
picam2.configure(config)
picam2.start()
picam2.set_controls({
    "ExposureTime": 100,
    "AnalogueGain": 1.0
})

FRAME_W = 640
FRAME_H = 480

LOCK_THRESHOLD = 5
LOCK_LOST_THRESHOLD = 60
MAX_JUMP = 200
BRIGHTNESS_THRESHOLD = 200

tracked_cx = None
tracked_cy = None

lock_counter = 0
lost_counter = 0
is_locked = False

force_unlock = False
unlock_cooldown_until = 0

velocity_x = 0.0
velocity_y = 0.0

predicted_cx = None
predicted_cy = None

smooth_cx = 0
smooth_cy = 0

frame_count = 0
fps_start = time.time()
current_fps = 0.0

latest_jpeg = None
jpeg_lock = threading.Lock()

ser = serial.Serial(
    "/dev/serial0",
    baudrate=115200,
    timeout=0.01
)


def find_closest_contour(contours, cx, cy):
    best = None
    best_dist = float("inf")
    best_cx = 0
    best_cy = 0

    for c in contours:
        M = cv2.moments(c)

        if M["m00"] == 0:
            continue

        ccx = int(M["m10"] / M["m00"])
        ccy = int(M["m01"] / M["m00"])

        dist = ((ccx - cx) ** 2 + (ccy - cy) ** 2) ** 0.5

        if dist < best_dist:
            best_dist = dist
            best = c
            best_cx = ccx
            best_cy = ccy

    return best, best_cx, best_cy, best_dist


def camera_loop():
    global tracked_cx, tracked_cy
    global lock_counter, lost_counter, is_locked
    global smooth_cx, smooth_cy
    global force_unlock, unlock_cooldown_until
    global velocity_x, velocity_y
    global predicted_cx, predicted_cy
    global frame_count, fps_start, current_fps
    global latest_jpeg

    while True:
        frame_count += 1
        elapsed = time.time() - fps_start

        if elapsed >= 1.0:
            current_fps = frame_count / elapsed
            frame_count = 0
            fps_start = time.time()

        frame = picam2.capture_array()
        frame = cv2.cvtColor(frame, cv2.COLOR_BGRA2RGB)

        gray = cv2.cvtColor(frame, cv2.COLOR_RGB2GRAY)

        _, mask = cv2.threshold(
            gray,
            BRIGHTNESS_THRESHOLD,
            255,
            cv2.THRESH_BINARY
        )

        mask_3ch = cv2.cvtColor(mask, cv2.COLOR_GRAY2RGB)
        frame = cv2.bitwise_and(frame, mask_3ch)

        contours, _ = cv2.findContours(
            mask,
            cv2.RETR_EXTERNAL,
            cv2.CHAIN_APPROX_SIMPLE
        )

        if force_unlock:
            tracked_cx = None
            tracked_cy = None

            lock_counter = 0
            lost_counter = 0
            is_locked = False
            force_unlock = False

            velocity_x = 0.0
            velocity_y = 0.0

            predicted_cx = None
            predicted_cy = None

            unlock_cooldown_until = time.time() + 10

        if time.time() >= unlock_cooldown_until:

            if len(contours) > 0:

                if tracked_cx is None:
                    best_c = max(contours, key=cv2.contourArea)
                    M = cv2.moments(best_c)

                    if M["m00"] > 0:
                        cx = int(M["m10"] / M["m00"])
                        cy = int(M["m01"] / M["m00"])

                        tracked_cx = cx
                        tracked_cy = cy

                        lock_counter = 1
                        lost_counter = 0

                        velocity_x = 0.0
                        velocity_y = 0.0

                else:
                    search_cx = (
                        predicted_cx
                        if predicted_cx is not None
                        else tracked_cx
                    )

                    search_cy = (
                        predicted_cy
                        if predicted_cy is not None
                        else tracked_cy
                    )

                    _, new_cx, new_cy, dist = find_closest_contour(
                        contours,
                        search_cx,
                        search_cy
                    )

                    if dist < MAX_JUMP:
                        velocity_x = (
                            velocity_x * 0.7
                            + (new_cx - tracked_cx) * 0.3
                        )

                        velocity_y = (
                            velocity_y * 0.7
                            + (new_cy - tracked_cy) * 0.3
                        )

                        tracked_cx = new_cx
                        tracked_cy = new_cy

                        lock_counter = min(
                            lock_counter + 1,
                            LOCK_THRESHOLD + 1
                        )

                        lost_counter = 0
                        predicted_cx = None
                        predicted_cy = None

                    else:
                        lost_counter += 1

                        predicted_cx = int(
                            tracked_cx + velocity_x
                        )

                        predicted_cy = int(
                            tracked_cy + velocity_y
                        )

            else:
                if tracked_cx is not None:
                    lost_counter += 1

                    predicted_cx = int(
                        tracked_cx + velocity_x
                    )

                    predicted_cy = int(
                        tracked_cy + velocity_y
                    )

            if lost_counter >= LOCK_LOST_THRESHOLD:
                tracked_cx = None
                tracked_cy = None

                lock_counter = 0
                lost_counter = 0
                is_locked = False

                velocity_x = 0.0
                velocity_y = 0.0

                predicted_cx = None
                predicted_cy = None

            is_locked = lock_counter >= LOCK_THRESHOLD

            # Rita grön box runt alla detekterade ljuskällor
            for c in contours:
                M = cv2.moments(c)

                if M["m00"] == 0:
                    continue

                ccx = int(M["m10"] / M["m00"])
                ccy = int(M["m01"] / M["m00"])

                size = 20

                cv2.rectangle(
                    frame,
                    (ccx - size, ccy - size),
                    (ccx + size, ccy + size),
                    (0, 255, 0),
                    1
                )

            # Rita tracking-box
            if tracked_cx is not None and lock_counter > 0:
                color = (
                    (255, 0, 0)
                    if is_locked
                    else (0, 255, 255)
                )

                size = 20

                cv2.rectangle(
                    frame,
                    (tracked_cx - size, tracked_cy - size),
                    (tracked_cx + size, tracked_cy + size),
                    color,
                    2
                )

                smooth_cx = tracked_cx
                smooth_cy = tracked_cy

                # Skicka endast koordinater när kameran är locked
                if is_locked:
                    data_coord = (
                        f"LOCK,{tracked_cx},{tracked_cy}\n"
                    )

                    ser.write(
                        data_coord.encode("utf-8")
                    )

            if predicted_cx is not None and lost_counter > 0:
                cv2.circle(
                    frame,
                    (predicted_cx, predicted_cy),
                    4,
                    (150, 150, 0),
                    1
                )

        cv2.putText(
            frame,
            f"FPS: {int(current_fps)}",
            (8, 18),
            cv2.FONT_HERSHEY_SIMPLEX,
            0.45,
            (140, 140, 140),
            1
        )

        _, jpeg = cv2.imencode(
            ".jpg",
            frame,
            [cv2.IMWRITE_JPEG_QUALITY, 60]
        )

        with jpeg_lock:
            latest_jpeg = jpeg.tobytes()


cam_thread = threading.Thread(
    target=camera_loop,
    daemon=True
)
cam_thread.start()


def generate():
    while True:
        with jpeg_lock:
            if latest_jpeg is None:
                time.sleep(0.01)
                continue

            frame_bytes = latest_jpeg

        yield (
            b"--frame\r\n"
            b"Content-Type: image/jpeg\r\n\r\n"
            + frame_bytes
            + b"\r\n"
        )


@app.route("/video")
def video():
    return Response(
        generate(),
        mimetype="multipart/x-mixed-replace; boundary=frame"
    )


@app.route("/video_frame")
def video_frame():
    with jpeg_lock:
        if latest_jpeg is None:
            return "", 503

        frame_bytes = latest_jpeg

    return Response(
        frame_bytes,
        mimetype="image/jpeg"
    )


@app.route("/status")
def status():
    return jsonify({
        "locked": is_locked,
        "cx": smooth_cx,
        "cy": smooth_cy,
        "fps": int(current_fps)
    })


@app.route("/unlock", methods=["POST"])
def unlock():
    global force_unlock

    force_unlock = True

    return jsonify({
        "ok": True
    })


if __name__ == "__main__":
    app.run(
        host="0.0.0.0",
        port=8080,
        threaded=True
    )




