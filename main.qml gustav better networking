            if (status !== "Intro") {
                switch(button) {
                case 0: a = 0; break
                case 1: b = 0; break
                case 2: x = 0; break
                case 3: y = 0; break
                case 9: shoulder_l = 0; break
                case 10: shoulder_r = 0; break
                }
                tcpButtons.sendMessage(a + "," + b + "," + x + "," + y + "," + shoulder_l + "," + shoulder_r)
            }
        }
