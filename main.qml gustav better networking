                    feedTimer.waitingForLoad = false
                }
            }
        }

        Image {
            id: feed2
            anchors.fill: parent
            fillMode: Image.Stretch
            cache: false
            visible: !turretItem.showFirst
            onStatusChanged: {
                if (status === Image.Ready) {
                    turretItem.showFirst = false
                    feedTimer.waitingForLoad = false
                } else if (status === Image.Error) {
                    feedTimer.waitingForLoad = false
                }
            }
        }

        Timer {
            id: feedTimer
            interval: 33
            running: true
            repeat: true
            property bool waitingForLoad: false
            onTriggered: {
                if (feedTimer.waitingForLoad) return
                feedTimer.waitingForLoad = true
                var url = "http://192.168.1.200:8080/video_frame?t=" + Date.now()
                if (turretItem.showFirst) {
                    feed2.source = url
                } else {
                    feed1.source = url
                }
            }
        }

