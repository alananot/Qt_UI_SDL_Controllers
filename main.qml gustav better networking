            anchors.right: parent.right
            anchors.top: parent.top
            anchors.margins: 20
            font.pixelSize: 18
            font.bold: true
            font.family: "Eurostile"
            background: Rectangle {
                radius: 4
                color: "#1A2333"
                border.color: "#3A4A66"
                border.width: 2
            }
            contentItem: Text {
                text: backBtn.text
                anchors.centerIn: parent
                color: "#AFC7FF"
                font: backBtn.font
            }
            onClicked: window.showTutorial = false
        }

        // Quit-knapp (vänster hörn)
        Button {
            id: tutorialQuit
            text: "Quit"
            anchors.left: parent.left
            anchors.top: parent.top
            anchors.margins: 20
            font.pixelSize: 18
            font.bold: true
            font.family: "Eurostile"
            background: Rectangle {
                radius: 4
                color: "#8A1F1F"
                border.color: "#C44A4A"
                border.width: 2
            }
            contentItem: Text {
                text: tutorialQuit.text
                anchors.centerIn: parent
                color: "white"
                font: tutorialQuit.font
            }
            onClicked: window.close()
        }
    }

    Timer {
        id: lockTimer
        interval: 1500
        repeat: false
        onTriggered: intro.locked = false
    }

    Timer {
        id: is_idle_time
        interval: 300000
        repeat: false
        onTriggered: {
            if (status != "Intro" && status != "error") {
                window.isidle = true
                status_light.color = "white"
            }
        }
    }

    function reset_idle() {
        window.isidle = false
        if (status != "Intro" && status != "error") {
            status_light.color = "green"
        } else if (status == "error") {
            status_light.color = "red"
        } else {
            status_light.color = "yellow"
        }
        client.sendMessage(status)
        is_idle_time.restart()
    }

    // Avfyra en missil (gör nästa ikon vit). Stannar på 0.
    function fireMissile() {
        if (window.missilesRemaining > 0)
            window.missilesRemaining -= 1
    }

    // Ladda om alla missiler (alla ikoner röda igen).
    function reloadMissiles() {
        window.missilesRemaining = 3
    }

    PropertyAnimation { id: fadeOutAnimation;  target: fadeoutintro; property: "opacity"; to: 0.0; duration: 1000 }
    PropertyAnimation { id: fadeOutAnimation2; target: saabLogo;     property: "opacity"; to: 0.0; duration: 1000 }
    PropertyAnimation { id: fadeOutHUD;        target: hudIntro;     property: "opacity"; to: 0.0; duration: 1200 }
    PropertyAnimation { id: fadeInAnimation2;  target: turretItem;   property: "opacity"; to: 1.0; duration: 1000 }
}
