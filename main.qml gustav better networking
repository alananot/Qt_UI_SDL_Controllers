                case 1: b = 1; break
                case 2: x = 1; break
                case 3: y = 1; break
                case 9: shoulder_l = 1; reloadMissiles(); break   // vänster axelknapp = ladda om
                case 10: shoulder_r = 1; fireMissile(); break     // höger axelknapp = avfyra
                }
